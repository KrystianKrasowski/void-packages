	vinstall jre/bin/javadoc 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jcmd 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jdb 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jfr 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jhsdb 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jinfo 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jmap 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jps 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jrunscript 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jstack 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jstat 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/jwebserver 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/keytool 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/rmiregistry 755 /opt/jetbrains/kotlin-lsp/jre/bin
	vinstall jre/bin/serialver 755 /opt/jetbrains/kotlin-lsp/jre/bin
}
