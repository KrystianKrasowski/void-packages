do_install() {
	vmkdir /opt/jetbrains/kotlin-lsp
	vcopy * /opt/jetbrains/kotlin-lsp
	vinstall kotlin-lsp.sh 755 /opt/jetbrains/kotlin-lsp
	vinstall jre/bin/java 755 /opt/jetbrains/kotlin-lsp/jre/bin
